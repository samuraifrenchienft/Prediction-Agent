# ── AI Backend (pick one) ─────────────────────────────────────────────────────
# OpenRouter — PRIMARY. Free models, no credit card. Get key at: https://openrouter.ai/keys
# OPEN_ROUTER_API_KEY=your_openrouter_key_here

# Groq — fallback if OPEN_ROUTER_API_KEY not set. FREE, fast. Get key at: https://console.groq.com/keys
# GROQ_API_KEY=your_groq_key_here

# ── News / Catalyst Feed ──────────────────────────────────────────────────────
# GNews — FREE tier, 100 req/day, no credit card. Get key at: https://gnews.io
GNEWS_API_KEY=your_gnews_key_here

# NewsAPI.org — fallback (free dev plan, 100 req/day). Get key at: https://newsapi.org
# NEWS_API_KEY=your_newsapi_key_here

# ── Market Data ───────────────────────────────────────────────────────────────
# Polymarket — NO KEY NEEDED. Public API used automatically.

# Kalshi — FREE account needed for real binary market data.
# Sign up at: https://kalshi.com → API Settings → Create key
# Without this key the adapter uses realistic mock markets.
# KALSHI_API_KEY=your_kalshi_key_here

# ── Discord Bot (Paying Users — one private channel per user) ─────────────────
# Create bot at: https://discord.com/developers/applications
# Enable Privileged Intents: Server Members + Message Content
# Bot permissions needed: Manage Channels, Send Messages, Read Message History,
#                         Embed Links, Use Slash Commands, Add Reactions
# Run: python run_discord_bot.py
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Right-click your Discord server → Copy Server ID
DISCORD_GUILD_ID=your_server_id_here

# Right-click the category where user channels should be created → Copy ID
DISCORD_CATEGORY_ID=your_category_id_here

# Your own Discord user ID (right-click yourself → Copy User ID)
DISCORD_OWNER_ID=your_discord_user_id_here
